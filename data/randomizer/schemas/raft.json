      "category": "general",
      "type": {
        "kind": "select",
        "default": "random_island_order",
        "choices": [
          {
            "value": "vanilla",
            "label": "Vanilla"
          },
          {
            "value": "random_on_island",
            "label": "Random On Island"
          },
          {
            "value": "random_island_order",
            "label": "Random Island Order"
          },
          {
            "value": "random_on_island_random_order",
            "label": "Random On Island Random Order"
          },
          {
            "value": "progressive",
            "label": "Progressive"
          },
          {
            "value": "anywhere",
            "label": "Anywhere"
          }
        ]
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "island_generation_distance",
      "label": "Island Generation Distance",
      "description": "Sets how far away islands spawn from you when you input their coordinates into the Receiver.",
      "category": "general",
      "type": {
        "kind": "select",
        "default": "vanilla",
        "choices": [
          {
            "value": "quarter",
            "label": "Quarter"
          },
          {
            "value": "half",
            "label": "Half"
          },
          {
            "value": "vanilla",
            "label": "Vanilla"
          },
          {
            "value": "double",
            "label": "Double"
          },
          {
            "value": "quadrouple",
            "label": "Quadrouple"
          }
        ]
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "expensive_research",
      "label": "Expensive Research",
      "description": "If No is selected, researching items and unlocking items in the Crafting Table works the same as vanilla Raft.",
      "category": "general",
      "type": {
        "kind": "toggle",
        "default": false
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "progressive_items",
      "label": "Progressive Items",
      "description": "Makes some items, like the Bow and Arrow, progressive rather than raw unlocks.",
      "category": "items",
      "type": {
        "kind": "toggle",
        "default": true
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "big_island_early_crafting",
      "label": "Big Island Early Crafting",
      "description": "Allows recipes that require items from big islands (eg leather) to lock earlygame items like the Receiver, Bolt, or Smelter.",
      "category": "general",
      "type": {
        "kind": "toggle",
        "default": false
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "paddleboard_mode",
      "label": "Paddleboard Mode",
      "description": "Sets later story islands to be in logic without an Engine or Steering Wheel.",
      "category": "general",
      "type": {
        "kind": "toggle",
        "default": false
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "death_link",
      "label": "Death Link",
      "description": "When you die, everyone who enabled death link dies.",
      "category": "general",
      "type": {
        "kind": "toggle",
        "default": false
      },
      "advanced": false,
      "dependencies": null
    }
  ],
  "presets": []
