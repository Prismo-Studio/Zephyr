{
  "id": "raft",
  "name": "Raft",
  "version": "0.3.4",
  "description": "Raft is a flooded world exploration game.",
  "meta": {
    "rom_required": false,
    "supported_versions": [],
    "wiki_url": null,
    "icon": "mdi:gamepad-variant"
  },
  "options": [
    {
      "id": "progression_balancing",
      "label": "Progression Balancing",
      "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.",
      "category": "general",
      "type": {
        "kind": "range",
        "min": 0,
        "max": 99,
        "step": 1,
        "default": 50
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "accessibility",
      "label": "Accessibility",
      "description": "Set rules for reachability of your items/locations.",
      "category": "logic",
      "type": {
        "kind": "select",
        "default": "full",
        "choices": [
          {
            "value": "full",
            "label": "Full"
          },
          {
            "value": "minimal",
            "label": "Minimal"
          }
        ]
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "minimum_resource_pack_amount",
      "label": "Minimum Resource Pack Amount",
      "description": "The minimum amount of resources available in a resource pack",
      "category": "general",
      "type": {
        "kind": "range",
        "min": 1,
        "max": 15,
        "step": 1,
        "default": 1
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "maximum_resource_pack_amount",
      "label": "Maximum Resource Pack Amount",
      "description": "The maximum amount of resources available in a resource pack",
      "category": "general",
      "type": {
        "kind": "range",
        "min": 1,
        "max": 15,
        "step": 1,
        "default": 5
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "duplicate_items",
      "label": "Duplicate Items",
      "description": "Adds duplicates of items to the item pool (if configured in Filler items).",
      "category": "items",
      "type": {
        "kind": "select",
        "default": "any",
        "choices": [
          {
            "value": "progression",
            "label": "Progression"
          },
          {
            "value": "non_progression",
            "label": "Non Progression"
          },
          {
            "value": "any",
            "label": "Any"
          }
        ]
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "filler_item_types",
      "label": "Filler Item Types",
      "description": "Determines whether to use Resource Packs, Duplicate Items (as configured), or both.",
      "category": "items",
      "type": {
        "kind": "select",
        "default": "resource_packs",
        "choices": [
          {
            "value": "resource_packs",
            "label": "Resource Packs"
          },
          {
            "value": "duplicates",
            "label": "Duplicates"
          },
          {
            "value": "both",
            "label": "Both"
          }
        ]
      },
      "advanced": false,
      "dependencies": null
    },
    {
      "id": "island_frequency_locations",
