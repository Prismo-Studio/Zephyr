{
	"productName": "Zephyr",
	"version": "0.7.0",
	"identifier": "com.prismo-studio.zephyr",
	"build": {
		"beforeBuildCommand": "pnpm run build",
		"beforeDevCommand": "pnpm run dev",
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173"
	},
	"bundle": {
		"active": true,
		"category": "Game",
		"copyright": "",
		"targets": "all",
		"externalBin": [],
		"createUpdaterArtifacts": true,
		"shortDescription": "A fast, modern mod manager for all your games",
		"longDescription": "",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"windows": {
			"certificateThumbprint": null,
			"digestAlgorithm": "sha256",
			"timestampUrl": ""
		},
		"linux": {
			"deb": {
				"depends": []
			}
		},
		"macOS": {
			"dmg": {
				"appPosition": { "x": 180, "y": 170 },
				"applicationFolderPosition": { "x": 480, "y": 170 }
			},
			"minimumSystemVersion": "10.15"
		},
		"resources": [],
		"fileAssociations": [
			{
				"ext": ["r2z"],
				"mimeType": "application/zip"
			}
		]
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDRkNCMzE4NDIyOTQ1QjQKUldTMFJTbENHTFA4UE9Fd1RocjRDRm9uVmdiUlUxdmw1ZEwvaXRJZW45VFVSeXozUkYxaUFmZEsK",
			"endpoints": [
				"https://raw.githubusercontent.com/Prismo-Studio/Zephyr/refs/heads/dev/latest.json"
			]
		},
		"deep-link": {
			"desktop": {
				"schemes": ["ror2mm", "zephyr"]
			}
		}
	},
	"app": {
		"windows": [
			{
				"visible": false,
				"decorations": false,
				"fullscreen": false,
				"transparent": false,
				"resizable": true,
				"title": "Zephyr",
				"width": 900,
				"height": 700,
				"minWidth": 800,
				"minHeight": 600,
				"dragDropEnabled": false
			}
		],
		"security": {
			"csp": "default-src * ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' https://storage.ko-fi.com; font-src https://fonts.gstatic.com",
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	}
}
